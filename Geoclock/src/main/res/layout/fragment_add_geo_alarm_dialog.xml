<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Location preview row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/location_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?android:textColorSecondary"
                        android:inputType="text"
                        android:singleLine="true"
                        android:hint="@string/place_name_hint"
                        android:text=""/>

                    <TextView
                        android:id="@+id/radius_preview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary"/>

                </LinearLayout>

                <Button
                    android:id="@+id/change_location_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/change_location"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Time -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="?android:textColorSecondary"
                android:text="@string/add_geo_alarm_time_label"
                android:layout_marginBottom="4dp"/>

            <TimePicker
                android:id="@+id/add_geo_alarm_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- Ringtone picker row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ringtone_label"
                    android:textStyle="bold"
                    android:textColor="?android:textColorSecondary"/>

                <TextView
                    android:id="@+id/ringtone_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/ringtone_default"
                    android:textColor="?android:textColorPrimary"
                    android:gravity="end"/>

                <Button
                    android:id="@+id/ringtone_pick_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_sound"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Days -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="?android:textColorSecondary"
                android:text="@string/add_geo_alarm_days_label"
                android:layout_marginBottom="4dp"/>

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:layout_marginBottom="8dp">

                <TableRow>
                    <CheckBox android:id="@+id/sun" android:layout_gravity="center_horizontal"/>
                    <CheckBox android:id="@+id/mon" android:layout_gravity="center_horizontal"/>
                    <CheckBox android:id="@+id/tues" android:layout_gravity="center_horizontal"/>
                    <CheckBox android:id="@+id/wed" android:layout_gravity="center_horizontal"/>
                    <CheckBox android:id="@+id/thu" android:layout_gravity="center_horizontal"/>
                    <CheckBox android:id="@+id/fri" android:layout_gravity="center_horizontal"/>
                    <CheckBox android:id="@+id/sat" android:layout_gravity="center_horizontal"/>
                </TableRow>

                <TableRow>
                    <TextView android:text="@string/sunday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                    <TextView android:text="@string/monday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                    <TextView android:text="@string/tuesday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                    <TextView android:text="@string/wednesday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                    <TextView android:text="@string/thursday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                    <TextView android:text="@string/friday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                    <TextView android:text="@string/saturday" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center"/>
                </TableRow>

            </TableLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Button row: Delete (text, red, left) | Space | Cancel (outlined) | Save (filled) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/add_geo_alarm_delete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_geo_alarm_delete"
            android:textColor="#B00020"
            android:visibility="gone"/>

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/add_geo_alarm_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/add_geo_alarm_cancel"/>

        <Button
            android:id="@+id/add_geo_alarm_save"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_geo_alarm_continue"/>

    </LinearLayout>

</LinearLayout>
