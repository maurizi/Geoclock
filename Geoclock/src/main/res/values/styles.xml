<resources>
    <!-- Base application theme. MaterialComponents bridge theme enables Material button styles
         while keeping all existing AppCompat code working unchanged. -->
    <style name="AppTheme" parent="@style/Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Customize your theme here. -->
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AlarmRingingTheme" parent="@style/Theme.MaterialComponents.Light.DarkActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

</resources>
